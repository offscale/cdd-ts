{
    "name": "cdd-ts",
    "version": "0.0.1",
    "description": "OpenAPI ↔ TypeScript",
    "keywords": [
        "openapi",
        "cdd",
        "angular",
        "codegen",
        "parser",
        "emitter",
        "compiler"
    ],
    "homepage": "https://github.com/offscale/cdd-ts#readme",
    "bugs": {
        "url": "https://github.com/offscale/cdd-ts/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/offscale/cdd-ts.git"
    },
    "license": "MIT",
    "author": "Samuel Marks <807580+SamuelMarks@users.noreply.github.com>",
    "type": "module",
    "bin": {
        "cdd-ts": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "package.json",
        "README.md"
    ],
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml}": [
            "prettier --write"
        ]
    },
    "scripts": {
        "check:types": "type-coverage --project ./tsconfig.json --detail --ignore-files \"tests/**/*.ts\"",
        "clean": "rm -rf dist docs coverage .vitest-cache node_modules/.vite",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && chmod +x dist/cli.js",
        "docs": "typedoc",
        "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
        "prepublishOnly": "npm run build",
        "start": "node dist/cli.js",
        "test": "vitest run --run",
        "test:coverage": "vitest run --run --coverage",
        "prepare": "husky",
        "format": "eslint --fix 'src/**/*.ts' 'tests/**/*.ts'",
        "eslint": "eslint 'src/**/*.ts' 'tests/**/*.ts'"
    },
    "dependencies": {
        "@ts-morph/common": "file:../ts-morph/packages/common",
        "@typescript/native-preview": "^7.0.0-dev.20260505.1",
        "as-wasi": "^0.6.0",
        "commander": "^14",
        "js-yaml": "^4.1.1",
        "path-browserify": "^1.0.1",
        "ts-morph": "file:../ts-morph/packages/ts-morph"
    },
    "devDependencies": {
        "@angular/common": "^21.2.11",
        "@angular/compiler": "^21.2.11",
        "@eslint/js": "^9.39.4",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25",
        "@types/swagger-schema-official": "^2.0.25",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "@vitest/coverage-istanbul": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unicorn": "^64.0.0",
        "glob": "^13.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.3",
        "swagger-schema-official": "^2.0.0-bab6bed",
        "tsc-alias": "^1.8.17",
        "type-coverage": "^2.29.7",
        "typedoc": "^0.28.19",
        "vitest": "^4.1"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
