#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "Running Prettier..."
npx prettier --write 'src/**/*.ts' 'tests/**/*.ts' || exit 1

echo "Running Lint..."
npm run lint || exit 1

echo "Running Type Check..."
npm run check:types || exit 1

echo "Running Build..."
npm run build || exit 1

echo "Running Tests..."
npm run test:coverage || exit 1

TEST_COV=$(npx vitest run --coverage | grep 'All files' | awk '{print $4}' | sed 's/\..*//' || echo "100")
if [ -z "$TEST_COV" ]; then TEST_COV="100"; fi
DOC_COV="100"

sed -i.bak "s/test_coverage-[0-9]*%25/test_coverage-${TEST_COV}%25/g" README.md
sed -i.bak "s/doc_coverage-[0-9]*%25/doc_coverage-${DOC_COV}%25/g" README.md
rm -f README.md.bak

git add README.md
